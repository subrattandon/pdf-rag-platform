{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "web",
      "source": {
        "repo": "https://github.com/subrattandon/pdf-rag-platform.git",
        "rootDir": "backend"
      },
      "build": {
        "dockerfilePath": "Dockerfile"
      },
      "start": {
        "cmd": "bash ./scripts/entrypoint.sh"
      },
      "deploy": {
        "healthcheck": {
          "path": "/api/v1/health/live",
          "timeout": 10
        },
        "restartPolicy": {
          "maxRetries": 3
        }
      },
      "variables": {
        "PORT": "8000",
        "WEB_CONCURRENCY": "1"
      }
    },
    {
      "name": "worker",
      "source": {
        "repo": "https://github.com/subrattandon/pdf-rag-platform.git",
        "rootDir": "backend"
      },
      "build": {
        "dockerfilePath": "Dockerfile"
      },
      "start": {
        "cmd": "celery -A app.workers worker -l info --concurrency=2"
      },
      "deploy": {
        "restartPolicy": {
          "maxRetries": 5
        }
      },
      "variables": {
        "CELERY_BROKER": "${{REDIS_URL}}"
      }
    }
  ]
}