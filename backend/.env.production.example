# PDF Sage — Production Environment Configuration (Backend)
# Copy to `.env.production` and fill in real values, or set these as Railway
# service variables. All values must be production-grade (no test keys).

# ===========================
# Database (Neon PostgreSQL)
# ===========================
# Async driver used by FastAPI. Neon provides a pooled connection string.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/pdfsage?sslmode=require
# Sync driver used by Alembic + Celery worker (SQLAlchemy sync engine).
DATABASE_URL_SYNC=postgresql+psycopg2://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/pdfsage?sslmode=require

# ===========================
# Redis (Upstash)
# ===========================
# Upstash REST/Redis URL for Celery broker + result backend.
REDIS_URL=rediss://default:PASSWORD@xxx-xxxx-xxxx.upstash.io:6379

# ===========================
# Clerk Auth (production keys)
# ===========================
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# ===========================
# LLM (OpenRouter)
# ===========================
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# Embeddings are generated via OpenRouter's /embeddings endpoint.
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ===========================
# Vector DB (Qdrant Cloud)
# ===========================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=document_chunks

# ===========================
# Cloudflare R2 (file storage)
# ===========================
R2_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=pdfsage-uploads
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# ===========================
# Stripe (billing — optional, leave blank to disable)
# ===========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ===========================
# Sentry (error tracking — optional)
# ===========================
SENTRY_DSN=

# ===========================
# CORS (trusted origins)
# ===========================
# JSON array. MUST include your Vercel frontend URL.
CORS_ORIGINS=["https://pdf-sage.vercel.app","https://pdf-sage-xxx.vercel.app"]

# ===========================
# LangSmith tracing (optional)
# ===========================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=pdf-sage

# ===========================
# Runtime
# ===========================
DEBUG=false
PORT=8000
WEB_CONCURRENCY=1