# PDF Sage — Production Environment Configuration (Frontend / Vercel)
# Set these as Vercel project environment variables (Settings → Environment Variables).
# Only NEXT_PUBLIC_* variables are exposed to the browser.

# Public Clerk publishable key (exposed to browser). Leave blank to run in demo mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk secret key (server-side only). Leave blank to run in demo mode.
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_URL=/

# Public backend URL (exposed to browser). Point to your Railway backend domain.
NEXT_PUBLIC_API_URL=https://pdf-sage-backend.up.railway.app